<div class="detail-card-inner">

    <!-- LEFT: IMAGE -->
    <div class="detail-image">
        <img src="<%= vehicle.inv_image %>"
             alt="<%= vehicle.inv_make %> <%= vehicle.inv_model %>">
    </div>

    <!-- RIGHT: INFO -->
    <div class="detail-info">

        <h2 class="vehicle-title">
            <%= vehicle.inv_year %>
            <%= vehicle.inv_make %>
            <%= vehicle.inv_model %>
        </h2>

        <ul class="vehicle-specs">
            <li><strong>Price:</strong> $<%= vehicle.inv_price %></li>
            <li><strong>Mileage:</strong> <%= vehicle.inv_miles %></li>
            <li><strong>Color:</strong> <%= vehicle.inv_color %></li>
            <li><strong>Classification:</strong> <%= vehicle.classification_name %></li>
        </ul>

        <!-- NARROW DESCRIPTION WRAPPER -->
        <div class="vehicle-desc-wrap">
            <div class="vehicle-desc">
                <p><%= vehicle.inv_description %></p>
            </div>
        </div>

    </div>

</div>