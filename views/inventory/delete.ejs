<section class="page-title-card">
    <h1><%= title %></h1>
</section>

<!-- Optional message area (safe fallback) -->
<% if (typeof flash !== "undefined" && flash.error && flash.error.length > 0) { %>
<div class="flash flash--error"><%= flash.error[0] %></div>
<% } %>

<% if (typeof flash !== "undefined" && flash.notice && flash.notice.length > 0) { %>
<div class="notice"><%= flash.notice[0] %></div>
<% } %>

<!-- Vehicle details (your original structure preserved) -->
<div class="vehicle-detail">
    <%- detailHtml %>
</div>

<!-- Delete confirmation section -->
<section class="delete-confirmation">
    <p>Are you sure you want to delete this vehicle?</p>

    <h3>
        <%= vehicle.inv_make %> <%= vehicle.inv_model %>
    </h3>

    <form method="POST"
          action="/inv/delete">
        <input type="hidden"
               name="inv_id"
               value="<%= vehicle.inv_id %>">

        <button type="submit"
                class="btn-delete">
            Yes, Delete
        </button>

        <a href="/inv/"
           class="btn-cancel">
            Cancel
        </a>
    </form>
</section>