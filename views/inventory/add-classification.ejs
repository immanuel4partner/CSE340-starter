<section class="inv-form-card">
    <h1><%= title %></h1>

    <% if (flash && flash.notice && flash.notice.length) { %>
    <div class="notice"><%= flash.notice[0] %></div>
    <% } %>

    <% if (flash && flash.success && flash.success.length) { %>
    <div class="flash flash--success"><%= flash.success[0] %></div>
    <% } %>

    <% if (flash && flash.error && flash.error.length) { %>
    <div class="flash flash--error"><%= flash.error[0] %></div>
    <% } %>

    <% if (errors && errors.length) { %>
    <ul class="notice">
        <% errors.forEach(e => { %>
        <li><%= e.msg %></li>
        <% }) %>
    </ul>
    <% } %>

    <form action="/inv/add-classification"
          method="post">
        <div class="inv-form-grid inv-form-grid-one">
            <div class="form-field">
                <label for="classification_name">Classification Name</label>
                <input type="text"
                       id="classification_name"
                       name="classification_name"
                       required
                       pattern="^[A-Za-z0-9 -]+$"
                       title="Letters, numbers, spaces, and hyphens only."
                       value="<%= classification_name || '' %>" />
            </div>
        </div>

        <div class="inv-form-actions">
            <button type="submit">Add Classification</button>
        </div>
    </form>
</section>