<section class="inv-form-card">
    <h1><%= title %></h1>

    <!-- FLASH -->
    <% if (flash && flash.notice && flash.notice.length) { %>
    <div class="notice"><%= flash.notice[0] %></div>
    <% } %>

    <% if (flash && flash.error && flash.error.length) { %>
    <div class="flash flash--error"><%= flash.error[0] %></div>
    <% } %>

    <!-- ERRORS -->
    <% if (typeof errors !== "undefined" && errors.length) { %>
    <ul class="notice">
        <% errors.forEach(e => { %>
        <li><%= e.msg %></li>
        <% }) %>
    </ul>
    <% } %>

    <p>Are you sure you want to delete this vehicle? This cannot be undone.</p>

    <!-- VEHICLE DISPLAY -->
    <div class="vehicle-preview">

        <!-- IMAGE -->
        <img src="<%= inv_image %>"
             alt="<%= inv_make %> <%= inv_model %>"
             style="max-width:300px;">

        <!-- DETAILS -->
        <ul>
            <li><strong>Vehicle:</strong> <%= inv_make %> <%= inv_model %></li>
            <li><strong>Year:</strong> <%= inv_year %></li>
            <li><strong>Price:</strong> $<%= inv_price %></li>
            <li><strong>Mileage:</strong> <%= inv_miles %></li>
            <li><strong>Color:</strong> <%= inv_color %></li>
        </ul>

        <% if (inv_description) { %>
        <p><strong>Description:</strong> <%= inv_description %></p>
        <% } %>

    </div>

    <!-- FORM -->
    <form action="/inv/delete"
          method="post">
        <input type="hidden"
               name="inv_id"
               value="<%= inv_id %>">

        <button type="submit">Confirm Delete</button>
        <a href="/inv/">Cancel</a>
    </form>
</section>