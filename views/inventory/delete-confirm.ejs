<section class="inv-form-card">
    <h1><%= title %></h1>

    <!-- ===== FLASH MESSAGES (SAFE) ===== -->
    <% if (flash && flash.notice && flash.notice.length) { %>
    <div class="notice"><%= flash.notice[0] %></div>
    <% } %>

    <% if (flash && flash.success && flash.success.length) { %>
    <div class="flash flash--success"><%= flash.success[0] %></div>
    <% } %>

    <% if (flash && flash.error && flash.error.length) { %>
    <div class="flash flash--error"><%= flash.error[0] %></div>
    <% } %>

    <!-- ===== ERROR DISPLAY ===== -->
    <% if (errors && errors.length) { %>
    <ul class="notice">
        <% errors.forEach(e => { %>
        <li><%= e.msg %></li>
        <% }) %>
    </ul>
    <% } %>

    <p>Are you sure you want to delete this vehicle? This cannot be undone.</p>

    <!-- ===== VEHICLE DETAILS ===== -->
    <ul>
        <li>
            <strong>Vehicle:</strong>
            <%= vehicle.inv_make %> <%= vehicle.inv_model %>
        </li>

        <li>
            <strong>Year:</strong>
            <%= vehicle.inv_year %>
        </li>

        <li>
            <strong>Price:</strong>
            <%= vehicle.inv_price %>
        </li>
    </ul>

    <!-- ===== DELETE FORM ===== -->
    <form action="/inv/delete"
          method="post">
        <input type="hidden"
               name="inv_id"
               value="<%= vehicle.inv_id %>">

        <button type="submit">Confirm Delete</button>
        <a href="/inv/">Cancel</a>
    </form>
</section>