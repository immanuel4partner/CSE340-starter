<div class="auth-wrapper">

    <!-- Small title strip -->
    <div class="auth-header">
        <h1>
            <%= title %>
        </h1>
        <p class="form-note">
            <span class="required">*</span> All fields are required.
        </p>
    </div>

    <!-- Main form card -->
    <form class="account-form" method="post" action="/account/login">

        <label for="account_email">Email (Username)</label>
        <input type="email" id="account_email" name="account_email" required>

        <label for="account_password">Password</label>
        <div class="password-field">
            <input type="password" id="account_password" name="account_password" required>
            <button type="button" class="toggle-password">👁️</button>
        </div>

        <div class="password-help">
            <p class="password-title">Password Requirements</p>
            <ul class="password-rules">
                <li>12 characters minimum</li>
                <li>At least 1 capital letter</li>
                <li>At least 1 number</li>
                <li>At least 1 special character</li>
            </ul>
        </div>

        <button type="submit">Login</button>

        <!-- Small footer strip -->
        <div class="account-alt">
            <p>
                No account?
                <a href="/account/register" class="auth-link">Register here</a>
            </p>
        </div>

    </form>

</div>

<script src="/js/password-toggle.js"></script>