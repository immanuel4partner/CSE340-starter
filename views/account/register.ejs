<div class="auth-wrapper">

    <!-- Header (MATCH LOGIN) -->
    <div class="auth-header">
        <h1><%= title %></h1>

        <% if (errors) { %>
        <ul class="notice">
            <% errors.array?.().forEach(error => { %>
            <li><%= error.msg %></li>
            <% }) %>
        </ul>
        <% } %>
    

        <p class="form-note">
            <span class="required">*</span> All fields are required.
        </p>
    </div>

    <!-- FORM -->
    <form class="account-form"
          action="/account/register"
          method="post">

        <label for="account_firstname">First name</label>
        <input type="text"
               id="account_firstname"
               name="account_firstname"
               required
               value="<%= account_firstname %>">

        <label for="account_lastname">Last name</label>
        <input type="text"
               id="account_lastname"
               name="account_lastname"
               required
               value="<%= account_lastname %>">

        <label for="account_email">Email (Username)</label>
        <input type="email"
               id="account_email"
               name="account_email"
               required
               value="<%= account_email %>">

        <!-- PASSWORD WITH TOGGLE (MATCH LOGIN) -->
        <label for="account_password">Password</label>
        <div class="password-field">
            <input type="password"
                   id="account_password"
                   name="account_password"
                   required
                   pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$"
                   title="Must be at least 12 characters and include 1 uppercase, 1 lowercase, 1 number, and 1 special character.">
            <button type="button"
                    class="toggle-password"
                    data-target="account_password"
                    aria-pressed="false">
                👁️
            </button>
            </div>

        <!-- SAME PASSWORD HELP BOX -->
        <div class="password-help">
            <p class="password-title">Passw
                ord Requirements</p>
            <ul class="password-rules">
                <li>12 characters minimum</li>
                <li>At least 1 capital letter</li>
                <li>At least 1 number</li>
                <li>At least 1 special character</li>
            </ul>
        </div>

        <button type="submit">Register</button>

        <!-- FOOTER (MATCH LOGIN) -->
        <div class="account-alt">
            <p>
                Already have an account?
                <a href="/account/login"
                   class="auth-link">Login here</a>
            </p>
        </div>

    </form>

</div>

<script src="/js/password-toggle.js"></script>