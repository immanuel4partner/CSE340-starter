<main class="account-management-page">
    <h1>
        <%= title %>
    </h1>

    <% if (locals.loggedin && locals.accountData) { %>
    <div class="account-card">
        <h2>Welcome <%= locals.accountData.account_firstname %>
        </h2>

        <div class="account-section">
            <a href="/account/update/<%= locals.accountData.account_id %>"
               class="account-link">
                Update Account Information
            </a>
        </div>

        <% if (locals.accountData.account_type==="Employee" || locals.accountData.account_type==="Admin" ) { %>
        <h3>Inventory Management</h3>
        <div class="account-section">
            <a href="/inv/"
               class="account-link">Manage Inventory</a>
        </div>
        <% } %>
    </div>
    <% } else { %>
    <div class="account-card">
        <p>You are not logged in.</p>
        <div class="account-section">
            <a href="/account/login"
               class="account-link">Login</a>
        </div>
    </div>
    <% } %>
</main>