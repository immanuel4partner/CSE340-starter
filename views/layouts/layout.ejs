<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible"
          content="IE=edge" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />
    <meta name="description"
          content="Browse our vehicle inventory at CSE Motors. View detailed information including pricing, mileage, and specifications.">
    <title><%= title %> | CSE 340 App</title>
    <link rel="stylesheet"
          href="/css/styles.css" />
  </head>

  <body class="<%= typeof pageClass !== 'undefined' ? pageClass : '' %>">
    <div class="page-shell">

      <!-- HEADER -->
      <header id="top-header">
        <div class="header-inner">
          <div class="siteName">
            <a href="/"
               title="Home page">CSE Motors</a>
          </div>

          <!-- ✅ FIXED ACCOUNT SECTION -->
          <div class="account">
            <% if (loggedin) { %>
            <a href="/account"
               title="My account">My Account</a> |
            <a href="/account/logout"
               title="Logout">Logout</a>
            <% } else { %>
            <a href="/account/login"
               title="Login">My Account</a>
            <% } %>
          </div>

        </div>
      </header>

      <!-- NAVIGATION -->
      <nav class="main-nav"
           aria-label="Primary navigation">
        <%- locals.nav || "" %>
      </nav>

      <!-- FLASH MESSAGES -->
      <%- include("../partials/flash") %>

      <!-- MAIN CONTENT -->
      <main id="main-content">
        <%- body %>
      </main>

      <!-- FOOTER -->
      <footer class="site-footer"
              role="contentinfo">
        <%- include("../partials/footer") %>
      </footer>

    </div>
  </body>

</html>