
<header id="top-header">
    <div class="header-inner">
        <span class="siteName">
            <a href="/"
               title="Return to home page">CSE Motors</a>
        </span>

        <div id="tools"
             class="account">
            <% if (loggedin && accountData) { %>
            <span class="welcome">Welcome <%= accountData.account_firstname %></span> |
            <a href="/account/logout">Logout</a>
            <% } else { %>
            <a href="/account/login">My Account</a>
            <% } %>
        </div>
    </div>

