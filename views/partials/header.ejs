<header id="top-header">
    <div class="header-inner">
        <span class="siteName">
            <a href="/"
               title="Return to home page">CSE New Motors</a>
        </span>

        <div id="tools"
             class="account">
            <ul>

                <% if (loggedin && accountData) { %>
                <!-- ✅ LOGGED IN STATE -->

                <li>
                    <!-- Account management link (must be clickable + visible only when logged in) -->
                    <a href="/account/">
                        Welcome <%= accountData.account_firstname %>
                    </a>
                </li>

                <li>
                    <a href="/account/logout">Logout</a>
                </li>

                <% } else { %>
                <!-- ❌ LOGGED OUT STATE -->

                <li>
                    <a href="/account/login">My Account</a>
                </li>

                <% } %>

            </ul>
        </div>
    </div>
</header>